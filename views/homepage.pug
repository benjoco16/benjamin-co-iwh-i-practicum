doctype html
html
    head
        title= title
        meta(name="viewport" content="width=device-width, initial-scale=1")
        link(rel="stylesheet", href="/css/style.css")
    body
        main.page-wrapper
            h1 Custom Object Records
            a.action-link(href="/update-cobj") Add to this table

            if error
                p.error-message= error

            table.records-table
                thead
                    tr
                        th Name
                        th Category
                        th Price
                tbody
                    if data && data.length
                        each record in data
                            tr
                                td= record.properties.name || ''
                                td= record.properties.category || ''
                                td= record.properties.price || ''
                    else
                        tr
                            td(colspan="3") No custom object records found.
